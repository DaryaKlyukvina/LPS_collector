{"file":"_id_-D7EVDAT3.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;AAmKA,UAAM,QAAS,SAAA;AACf,UAAM,OAAS,aAAA;AAGf,UAAM,EAAE,MAAM,KAAK,WAAU,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAc,aAAa,MAAM,OAAO,EAAE;AAAA,MAAA;AAAA;AAAA,IAAA,CAAE;AAG/E,UAAM,SAAS,SAAS,MAAM;AAC5B,UAAI,CAAC,IAAI,MAAO,QAAO,CAAA;AACvB,YAAM,OAAwC,CAAA;AAC9C,UAAI,IAAI,MAAM,SAAU,MAAK,KAAK,EAAE,KAAK,IAAI,MAAM,UAAU;AAAA,UACxD,MAAK,KAAK,EAAE,KAAK,qCAAqC;AAC3D,aAAO;AAAA,IACT,CAAC;AAED,UAAM,iBAAiB,IAAI,CAAC;AAC5B,UAAM,cAAc,SAAS,MAAM,OAAO,MAAM,eAAe,KAAK,GAAG,OAAO,mCAAmC;AAGjH,UAAM,gBAAwC;AAAA,MAC5C,UAAU;AAAA,MAAO,SAAS;AAAA,MAAQ,UAAU;AAAA,MAC5C,MAAM;AAAA,MAAU,SAAS;AAAA,MAAQ,WAAW;AAAA,IAAA;AAE9C,UAAM,cAAc;AAAA,MAAS,MAC3B,cAAc,IAAI,OAAO,MAAM,WAAW,EAAE,KAAK;AAAA,IAAA;AAInD,UAAM,EAAE,MAAM,SAAS,SAAS,gBAAiB,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAS;AAAA;;KAAiB;AACjF,UAAM,EAAE,MAAM,UAAU,SAAS,iBAAgB,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAS;AAAA;;KAAe;AAE/E,UAAM,eAAe;AAAA,MAAS,OAC3B,QAAQ,SAAS,CAAA,GAAI,KAAK,CAAC,MAAW,EAAE,IAAI,OAAO,IAAI,OAAO,EAAE;AAAA,IAAA;AAEnE,UAAM,aAAa;AAAA,MAAS,OACzB,SAAS,SAAS,CAAA,GAAI,KAAK,CAAC,MAAW,EAAE,IAAI,OAAO,IAAI,OAAO,EAAE;AAAA,IAAA;AAqBpE,UAAM,EAAE,MAAM,aAAA,KAAiB,CAAA,QAAA,SAAA,IAAAA,iBAAA,MAAM;AAAA,MAAS;AAAA,MAAa;AAAA,QACzD,OAAO,SAAS,MAAM,IAAI,OAAO,MAAM,KAAK,EAAE,SAAS,IAAI,MAAM,KAAK,IAAI,OAAO,EAAA,IAAM,CAAA,CAAE;AAAA,MAAA;AAAA,MAC3F;AAAA;AAAA,IAAA,CAAC;AACD,UAAM,WAAW;AAAA,MAAS,OACvB,aAAa,OAAO,SAAS,CAAA,GAC3B,OAAO,CAAC,MAAW,EAAE,OAAO,IAAI,OAAO,EAAE,EACzC,MAAM,GAAG,CAAC;AAAA,IAAA;AAIf,YAAQ,EAAE,OAAO,SAAS,MAAM,IAAI,QAAQ,GAAG,IAAI,MAAM,IAAI,KAAK,IAAI,MAAM,MAAM,WAAW,KAAK,GAAG;;;UApOxFC,MAAA,GAAA,GAAG;;AAGA,cAAAC,mBAAA,qBAAA,EAAA,IAAG,cAAU;AAAA,2BAAvB,CAA0C,GAAAC,QAAAC,UAAA,aAAA;;;;;gCAAlB,SAAO;AAAA,cAAA;AAAA;;;;;AAEf,YAAAH,MAAA,GAAA,EAAI,YAAU;;YAAG,IAAE,wBAA0BA,MAAA,GAAA,EAAI,WAAW,MAAM;AAAA,UAAA;6BAAlF,CAEW,GAAAE,QAAAC,UAAA,aAAA;;yCADNH,MAAA,GAAA,EAAI,WAAW,KAAK,CAAA,EAAA;AAAA;;kDAApBA,MAAA,GAAA,EAAI,WAAW,KAAK,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;;;;0DAGhBI,eAAAJ,MAAA,GAAA,EAAI,IAAI,MAAQI,eAAA,OAAOJ,MAAA,GAAA,EAAI,MAAM,EAAE,SAAQ,GAAA,GAAA,CAAA,mGAMLA,MAAA,WAAA,CAAW,IAAA,iBAAA,CAAA,UAChDK,cAAA,OAAKL,MAAA,WAAA,CAAW,kBAAG,OAAKA,MAAA,GAAA,EAAI,IAAI;AAI7B,YAAAA,MAAA,MAAA,EAAO,SAAM,GAAA;;wBAEDA,MAAA,MAAA,GAAM,CAAjB,KAAK,MAAC;0DACqBA,MAAA,WAAA,CAAW,IAAA,EAAA,IAAUA,MAAA,cAAA,MAAmB,EAAA,CAAC,GAAA,WAAA,CAAA,wBAGtE,OAAK,IAAI,GAAG,IAAGK,cAAA,OAAK,IAAI,OAAOL,MAAA,GAAA,EAAI,IAAI;;;;;;;AAM/B,YAAAA,MAAA,IAAA,EAAK,YAAU;gFAGhBA,MAAA,YAAA,CAAY,IAAA,cAAA,+BAGZA,MAAA,YAAA,IAAY,gBAAA,YAAA,0BACpBA,MAAA,YAAA,IAAY,gBAAA,aAAA,4CAIPA,MAAA,UAAA,IAAU,aAAA,aAAA,KAAA,CAAA,+BAGPA,MAAA,UAAA,IAAU,uBAAA,aAAA,0BAClBA,MAAA,UAAA,IAAU,eAAA,WAAA;;;YAIL,OAAM;AAAA,YAAkB,IAAG;AAAA,UAAA;6BAArC,CAEW,GAAAE,QAAAC,UAAA,aAAA;;;;;kBADTG,YAA2B,KAAA,EAAxB,OAAM,iBAAe;AAAA,kCAAG,wBAC7B;AAAA,gBAAA;AAAA;;;;;gFAO2BF,eAAA,OAAOJ,MAAA,GAAA,EAAI,MAAM,EAAE,SAAQ,GAAA,GAAA,CAAA,gCACjCI,eAAAJ,MAAA,GAAA,EAAI,IAAI;AAGnB,YAAAA,MAAA,GAAA,EAAI,YAAU;8DACrBA,MAAA,GAAA,EAAI,WAAW,KAAK,sBAASA,MAAA,GAAA,EAAI,WAAW,SAAS,oBAAOA,MAAA,GAAA,EAAI,WAAW,WAAO,MAAA;;;;AAE3E,YAAAA,MAAA,GAAA,EAAI,MAAI;6DAA0BA,MAAA,GAAA,EAAI,KAAK,IAAI,sBAASA,MAAA,GAAA,EAAI,KAAK,OAAO;;;;AACxE,YAAAA,MAAA,GAAA,EAAI,aAAW;gDAAsBA,MAAA,GAAA,EAAI,YAAY,cAAW,aAAA,aAAA,KAAA,CAAA,qBACvEA,MAAA,GAAA,EAAI,YAAY,KAAK;;;;6KAUEA,MAAA,GAAA,EAAI,YAAY,SAAK,GAAA,6GAIrBA,MAAA,GAAA,EAAI,MAAM,QAAI,GAAA,4GAIdA,MAAA,GAAA,EAAI,MAAM,WAAO,GAAA,mHAIjBA,MAAA,GAAA,EAAI,aAAa,SAAK,UAAA,oHAItBA,MAAA,GAAA,EAAI,YAAY,aAAS,GAAA,mGAIzBI,eAAAJ,MAAA,GAAA,EAAI,eAAW,GAAA,8FAOzB,EAAA,iBAAA,OAAA,CAA0B,4DAENO,eAAA,CAAA,EAAA,IAAAP,MAAA,GAAA,EAAI,eAAW,WAAA,CAAA,gBACxCO,eAAAP,MAAA,GAAA,EAAI,cAAW,gBAAA,SAAA,uCAGUO,eAAA,CAAA,EAAA,IAAAP,MAAA,GAAA,EAAI,UAAA,GAAS,WAAA,CAAA,gBACtCO,eAAAP,MAAA,GAAA,EAAI,YAAS,gBAAA,SAAA,sCAGYO,eAAA,CAAA,EAAA,IAAAP,MAAA,GAAA,EAAI,WAAA,GAAU,WAAA,CAAA,gBACvCO,eAAAP,MAAA,GAAA,EAAI,aAAU,gBAAA,SAAA;AAMb,YAAAA,MAAA,GAAA,EAAI,aAAW;kGAET,EAAA,iBAAA,OAAyB,0CACpBI,eAAAJ,MAAA,GAAA,EAAI,WAAW;;;;;AAMnC,YAAAA,MAAA,QAAA,EAAS,QAAM;;AAMRQ,wBAAAR,MAAA,QAAA,IAAL,MAAC;;cAAe,KAAK,EAAE;AAAA,cAC9B,OAAM;AAAA,cAAS,IAAE,SAAW,EAAE,EAAE;AAAA,YAAA;+BAFlC,CAWW,GAAAE,QAAAC,UAAA,aAAA;;gEAP6BH,MAAA,WAAA,CAAW,IAAA,UAAA,CAAA,mCACzC,OAAK,EAAE,YAAQ,oCAAA,kBAA2C,OAAK,EAAE,IAAI,kFAGrDI,eAAA,OAAO,EAAE,MAAM,EAAE,SAAQ,GAAA,GAAA,CAAA,wCACzBA,eAAA,EAAE,IAAI;;;oBAL9BE,YAEM,OAAA;AAAA,sBAFD,OAAK,CAAC,YAAU,QAAiBN,MAAA,WAAA,CAAW,EAAA;AAAA,oBAAA;sBAC/CM,YAA6E,OAAA;AAAA,wBAAvE,KAAK,EAAE,YAAQ;AAAA,wBAA2C,KAAK,EAAE;AAAA,sBAAA;;oBAEzEA,YAGM,OAAA,EAHD,OAAM,WAAO;AAAA,sBAChBA,YAA+D,OAAA,EAA1D,OAAM,OAAA,GAAO,MAACG,gBAAG,OAAO,EAAE,MAAM,EAAE,SAAQ,GAAA,GAAA,CAAA,GAAA,CAAA;AAAA,sBAC/CH,YAAqC,SAAhC,OAAM,QAAA,GAAOG,gBAAI,EAAE,IAAI,GAAA,CAAA;AAAA,oBAAA;;;;;;;;;;;;iBAQtBT,MAAA,KAAA,GAAK;AAAE,cAAA,OAAAU,eAAAC,WAAA,EAAA,OAAM,gBAAY,MAAA,CAAA,CAAA,8DAAA;;UAG7B,OAAM;AAAA,UAAgB,IAAG;AAAA,QAAA;2BAAnC,CAAoE,GAAAT,QAAAC,UAAA,aAAA;;;;;gCAAtB,aAAW;AAAA,cAAA;AAAA;;;;;;;;;;;;;;;;;","names":["_withAsyncContext","_unref","_ssrRenderComponent","_push","_parent","_ssrInterpolate","_ssrRenderAttr","_createVNode","_ssrRenderClass","_ssrRenderList","_toDisplayString","_ssrRenderAttrs","_mergeProps"],"sources":["../../../../pages/pets/[id].vue"],"sourcesContent":["<template>\n  <div v-if=\"pet\">\n    <!-- Хлебные крошки -->\n    <div class=\"breadcrumb\">\n      <NuxtLink to=\"/catalog\">Каталог</NuxtLink>\n      <i class=\"ti ti-chevron-right\" />\n      <NuxtLink v-if=\"pet.generation\" :to=\"`/catalog?generations=${pet.generation.number}`\">\n        {{ pet.generation.label }}\n      </NuxtLink>\n      <i class=\"ti ti-chevron-right\" />\n      <span>{{ pet.name }} #{{ String(pet.number).padStart(4,'0') }}</span>\n    </div>\n\n    <div class=\"pet-detail\">\n      <!-- Левая колонка: изображения -->\n      <div class=\"pet-left\">\n        <div class=\"pet-preview fig\" :class=\"`tint-${speciesTint}`\">\n          <img :src=\"activeImage\" :alt=\"pet.name\" class=\"preview-img\">\n        </div>\n\n        <!-- Миниатюры доп. изображений -->\n        <div v-if=\"images.length > 1\" class=\"thumbs\">\n          <div\n            v-for=\"(img, i) in images\" :key=\"i\"\n            class=\"thumb fig\" :class=\"[`tint-${speciesTint}`, { on: activeImageIdx === i }]\"\n            @click=\"activeImageIdx = i\"\n          >\n            <img :src=\"img.url\" :alt=\"img.alt ?? pet.name\">\n          </div>\n        </div>\n\n        <!-- Кнопки действий -->\n        <div class=\"pet-actions\">\n          <template v-if=\"auth.isLoggedIn\">\n            <button\n              class=\"btn btn-primary\"\n              :disabled=\"inCollection\"\n              @click=\"addToCollection\"\n            >\n              <i :class=\"inCollection ? 'ti ti-check' : 'ti ti-plus'\" />\n              {{ inCollection ? 'В коллекции' : 'В коллекцию' }}\n            </button>\n            <button\n              class=\"btn\"\n              :class=\"inWishlist ? 'btn-soft' : 'btn-ghost'\"\n              @click=\"toggleWishlist\"\n            >\n              <i :class=\"inWishlist ? 'ti ti-heart-filled' : 'ti ti-heart'\" />\n              {{ inWishlist ? 'В вишлисте' : 'В вишлист' }}\n            </button>\n          </template>\n          <template v-else>\n            <NuxtLink class=\"btn btn-primary\" to=\"/auth\">\n              <i class=\"ti ti-login-2\" /> Войти чтобы добавить\n            </NuxtLink>\n          </template>\n        </div>\n      </div>\n\n      <!-- Правая колонка: информация -->\n      <div class=\"pet-right\">\n        <div class=\"pet-num-label\">#{{ String(pet.number).padStart(4,'0') }}</div>\n        <h1 class=\"pet-title\">{{ pet.name }}</h1>\n\n        <div class=\"tags-row\">\n          <span v-if=\"pet.generation\" class=\"tag tag-brand\">\n            {{ pet.generation.label }} · {{ pet.generation.yearStart }}–{{ pet.generation.yearEnd ?? 'н.в.' }}\n          </span>\n          <span v-if=\"pet.mold\" class=\"tag tag-mint\">{{ pet.mold.name }} · {{ pet.mold.species }}</span>\n          <span v-if=\"pet.releaseType\" class=\"tag\" :class=\"pet.releaseType.isExclusive ? 'tag-gold' : 'tag-brand'\">\n            {{ pet.releaseType.label }}\n          </span>\n        </div>\n\n        <div class=\"divider-h\" />\n\n        <!-- Характеристики -->\n        <div class=\"props-grid\">\n          <div class=\"prop\">\n            <span class=\"prop-label\">Поколение</span>\n            <span class=\"prop-val\">{{ pet.generation?.label ?? '—' }}</span>\n          </div>\n          <div class=\"prop\">\n            <span class=\"prop-label\">Молд</span>\n            <span class=\"prop-val\">{{ pet.mold?.name ?? '—' }}</span>\n          </div>\n          <div class=\"prop\">\n            <span class=\"prop-label\">Вид</span>\n            <span class=\"prop-val\">{{ pet.mold?.species ?? '—' }}</span>\n          </div>\n          <div class=\"prop\">\n            <span class=\"prop-label\">Тип релиза</span>\n            <span class=\"prop-val\">{{ pet.releaseType?.label ?? 'Standard' }}</span>\n          </div>\n          <div class=\"prop\">\n            <span class=\"prop-label\">Год выпуска</span>\n            <span class=\"prop-val\">{{ pet.generation?.yearStart ?? '—' }}</span>\n          </div>\n          <div class=\"prop\">\n            <span class=\"prop-label\">Расцветка</span>\n            <span class=\"prop-val\">{{ pet.colorScheme ?? '—' }}</span>\n          </div>\n        </div>\n\n        <div class=\"divider-h\" />\n\n        <!-- Особенности -->\n        <div class=\"sec-hd\" style=\"margin-bottom:10px\">Особенности</div>\n        <div class=\"feat-chips\">\n          <span class=\"feat-chip\" :class=\"{ on: pet.hasFlocking }\">\n            <i :class=\"pet.hasFlocking ? 'ti ti-check' : 'ti ti-x'\" />\n            Флокинг\n          </span>\n          <span class=\"feat-chip\" :class=\"{ on: pet.hasMagnet }\">\n            <i :class=\"pet.hasMagnet ? 'ti ti-check' : 'ti ti-x'\" />\n            Магнит\n          </span>\n          <span class=\"feat-chip\" :class=\"{ on: pet.hasGlitter }\">\n            <i :class=\"pet.hasGlitter ? 'ti ti-check' : 'ti ti-x'\" />\n            Глиттер\n          </span>\n        </div>\n\n        <!-- Описание -->\n        <template v-if=\"pet.description\">\n          <div class=\"divider-h\" />\n          <div class=\"sec-hd\" style=\"margin-bottom:8px\">Описание</div>\n          <div class=\"pet-desc\">{{ pet.description }}</div>\n        </template>\n      </div>\n    </div>\n\n    <!-- Похожие фигурки на том же молде -->\n    <div v-if=\"sameMold.length\" class=\"same-mold\">\n      <div class=\"section-head-row\">\n        <span class=\"sec-hd\">Тот же молд · другие расцветки</span>\n      </div>\n      <div class=\"same-grid\">\n        <NuxtLink\n          v-for=\"p in sameMold\" :key=\"p.id\"\n          class=\"pcard\" :to=\"`/pets/${p.id}`\"\n        >\n          <div class=\"pimg fig\" :class=\"`tint-${speciesTint}`\">\n            <img :src=\"p.imageUrl ?? '/images/placeholders/pet_thumb.svg'\" :alt=\"p.name\">\n          </div>\n          <div class=\"pbody\">\n            <div class=\"pnum\">#{{ String(p.number).padStart(4,'0') }}</div>\n            <div class=\"pname\">{{ p.name }}</div>\n          </div>\n        </NuxtLink>\n      </div>\n    </div>\n  </div>\n\n  <!-- Состояние загрузки / ошибка -->\n  <div v-else-if=\"error\" class=\"page-error\">\n    <i class=\"ti ti-mood-sad\" />\n    <div>Фигурка не найдена</div>\n    <NuxtLink class=\"btn btn-ghost\" to=\"/catalog\">← В каталог</NuxtLink>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nconst route  = useRoute()\nconst auth   = useAuthStore()\n\n// Загрузка фигурки\nconst { data: pet, error } = await useFetch<any>(`/api/pets/${route.params.id}`)\n\n// Изображения: берём из pet_images если есть, иначе image_url, иначе заглушку\nconst images = computed(() => {\n  if (!pet.value) return []\n  const imgs: { url: string; alt?: string }[] = []\n  if (pet.value.imageUrl) imgs.push({ url: pet.value.imageUrl })\n  else imgs.push({ url: '/images/placeholders/pet_card.svg' })\n  return imgs\n})\n\nconst activeImageIdx = ref(0)\nconst activeImage = computed(() => images.value[activeImageIdx.value]?.url ?? '/images/placeholders/pet_card.svg')\n\n// Тинт по виду животного\nconst SPECIES_TINTS: Record<string, string> = {\n  'Собака': 'lav', 'Кошка': 'mint', 'Кролик': 'peach',\n  'Ёж': 'butter', 'Хомяк': 'pink', 'Лягушка': 'sky',\n}\nconst speciesTint = computed(() =>\n  SPECIES_TINTS[pet.value?.mold?.species ?? ''] ?? 'lav'\n)\n\n// Статус в коллекции / вишлисте\nconst { data: colData, refresh: refreshCol }   = await useFetch('/api/collection')\nconst { data: wishData, refresh: refreshWish } = await useFetch('/api/wishlist')\n\nconst inCollection = computed(() =>\n  (colData.value ?? []).some((i: any) => i.pet.id === pet.value?.id)\n)\nconst inWishlist = computed(() =>\n  (wishData.value ?? []).some((i: any) => i.pet.id === pet.value?.id)\n)\n\nasync function addToCollection() {\n  if (!pet.value || inCollection.value) return\n  await $fetch('/api/collection', { method: 'POST', body: { petId: pet.value.id } })\n  refreshCol()\n}\n\nasync function toggleWishlist() {\n  if (!pet.value) return\n  if (inWishlist.value) {\n    const item = (wishData.value as any[]).find((i: any) => i.pet.id === pet.value!.id)\n    await $fetch(`/api/wishlist/${item.id}`, { method: 'DELETE' })\n  } else {\n    await $fetch('/api/wishlist', { method: 'POST', body: { petId: pet.value.id } })\n  }\n  refreshWish()\n}\n\n// Похожие фигурки (тот же молд, другой id)\nconst { data: sameMoldData } = await useFetch('/api/pets', {\n  query: computed(() => pet.value?.mold?.id ? { moldIds: pet.value.mold.id, limit: 8 } : {}),\n})\nconst sameMold = computed(() =>\n  (sameMoldData.value?.items ?? [])\n    .filter((p: any) => p.id !== pet.value?.id)\n    .slice(0, 6)\n)\n\n// SEO\nuseHead({ title: computed(() => pet.value ? `${pet.value.name} #${pet.value.number} — LPS` : 'LPS') })\n</script>\n\n<style lang=\"scss\">\n.breadcrumb {\n  @include flex-row(8px);\n  padding: 12px 22px;\n  font-size: 12.5px;\n  color: $ink-3;\n  border-bottom: 1px solid $line;\n  flex-wrap: wrap;\n\n  a { color: $ink-2; text-decoration: none; font-weight: 600; &:hover { color: $brand; } }\n  i { font-size: 14px; }\n  span { color: $ink; font-weight: 600; }\n}\n\n.pet-detail {\n  display: grid;\n  grid-template-columns: 240px 1fr;\n  gap: 0;\n}\n\n// Левая колонка\n.pet-left {\n  padding: 22px;\n  border-right: 1px solid $line;\n  display: flex;\n  flex-direction: column;\n  gap: 12px;\n}\n\n.pet-preview {\n  height: 200px;\n  border-radius: $r-lg;\n  border: 1px solid $line;\n  overflow: hidden;\n\n  .preview-img { width: 100%; height: 100%; object-fit: contain; padding: 8px; }\n}\n\n.thumbs { @include flex-row(6px); flex-wrap: wrap; }\n.thumb {\n  width: 48px; height: 48px;\n  border-radius: $r-sm; border: 1px solid $line;\n  cursor: pointer; overflow: hidden;\n  transition: .14s;\n\n  img { width: 100%; height: 100%; object-fit: cover; }\n  &.on { border-color: $brand; box-shadow: 0 0 0 2px $brand-tint; }\n  &:hover { border-color: $brand-line; }\n}\n\n.pet-actions { display: flex; flex-direction: column; gap: 8px; }\n.pet-actions .btn { justify-content: center; padding: 10px; }\n\n// Правая колонка\n.pet-right { padding: 22px 24px; }\n\n.pet-num-label { font-size: 12px; color: $ink-3; font-weight: 700; letter-spacing: .04em; margin-bottom: 4px; }\n\n.pet-title { @include font-display(26px); color: $ink; margin-bottom: 12px; line-height: 1.2; }\n\n.tags-row { @include flex-row(6px); flex-wrap: wrap; margin-bottom: 0; }\n\n.divider-h { height: 1px; background: $line; margin: 18px 0; }\n\n.props-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 10px 20px;\n  margin-bottom: 0;\n}\n\n.prop { display: flex; flex-direction: column; gap: 3px; }\n.prop-label { font-size: 10.5px; color: $ink-3; font-weight: 700; letter-spacing: .05em; text-transform: uppercase; }\n.prop-val   { font-size: 14px; color: $ink; font-weight: 600; }\n\n.feat-chips { @include flex-row(8px); flex-wrap: wrap; }\n.feat-chip {\n  @include flex-row(5px);\n  font-size: 12.5px; font-weight: 700;\n  padding: 5px 12px; border-radius: $r-pill;\n  border: 1px solid $line-2; color: $ink-3;\n  background: $bg-sunken;\n\n  i { font-size: 14px; }\n  &.on { background: $success-tint; border-color: $success-line; color: $success; }\n}\n\n.pet-desc {\n  font-size: 13.5px; color: $ink-2; line-height: 1.65;\n}\n\n// Блок похожих фигурок\n.same-mold {\n  border-top: 1px solid $line;\n  padding: 18px 22px 24px;\n}\n\n.section-head-row { margin-bottom: 14px; }\n\n.same-grid {\n  display: grid;\n  grid-template-columns: repeat(6, 1fr);\n  gap: 10px;\n}\n\n.pcard { @include card; cursor: pointer; }\n.pimg  { height: 80px; overflow: hidden; img { width: 100%; height: 100%; object-fit: contain; padding: 4px; } }\n.pbody { padding: 7px 9px 9px; }\n.pnum  { font-size: 10px; color: $ink-3; font-weight: 700; }\n.pname { @include font-display(12px, 600); margin-top: 1px; }\n\n.page-error {\n  display: flex; flex-direction: column; align-items: center; gap: 12px;\n  padding: 60px 20px; color: $ink-3;\n  i { font-size: 40px; }\n  div { font-size: 16px; font-weight: 600; }\n}\n</style>\n"],"version":3}